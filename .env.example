# ── LONDON SCALP AGENT — Environment Variables ──
# Copy this to .env and fill in your values

# TwelveData API key (can reuse same key as other agents)
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Discord webhook — create a NEW channel e.g. london-signals
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Symbols
SCALP_WATCHLIST=XAU/USD

# MT5 (keep false for now)
MT5_AUTO_TRADE=false

# Debug
DEBUG_MODE=false
